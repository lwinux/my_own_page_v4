# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=myownpage
POSTGRES_USER=myownpage
POSTGRES_PASSWORD=change-this-db-password

# ─── Redis ────────────────────────────────────────────────────────────────────
# Configured via docker-compose service name; override if external Redis
# REDIS_URL=redis://redis:6379/0

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-in-production-min-32-chars-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false

# ─── Frontend1 ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FRONTEND1_SECRET_KEY=change-this-frontend1-flask-secret
# false = HTTP (local/dev)  |  true = HTTPS only (production with TLS)
# ⚠️  Wrong value causes login session to drop → redirect-loop to /login
SESSION_COOKIE_SECURE=false

# ─── CORS / Origins ──────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com

# ─── Rate Limiting ───────────────────────────────────────────────────────────
FEATURE_RATE_LIMITING=true
RATE_LIMIT_AUTH=10/minute

# ─── Feature Flags ───────────────────────────────────────────────────────────
FEATURE_PDF_EXPORT=false
FEATURE_THEMES=false
